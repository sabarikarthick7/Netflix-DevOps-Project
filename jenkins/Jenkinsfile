// =====================================================
// Netflix Clone - Jenkins CI/CD Pipeline
// =====================================================
pipeline {

    agent any

    environment {
        DOCKERHUB_USERNAME = credentials('DOCKERHUB_USERNAME')
        DOCKERHUB_PASSWORD = credentials('DOCKERHUB_PASSWORD')

        FRONTEND_IMAGE = "${DOCKERHUB_USERNAME}/netflix-frontend"
        BACKEND_IMAGE  = "${DOCKERHUB_USERNAME}/netflix-backend"

        IMAGE_TAG = "${BUILD_NUMBER}"

        K8S_NAMESPACE = "netflix-clone"

        KUBECONFIG = credentials('KUBECONFIG')

        REACT_APP_API_URL = "http://netflix-backend-service:5000"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }

    triggers {
        pollSCM('H/5 * * * *')
    }

    stages {

        // Clone Repo
        stage('Clone Repository') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/sabarikarthick7/netflix-devops-project.git'
            }
        }

        // Install dependencies
        stage('Install Dependencies') {
            parallel {

                stage('Backend') {
                    steps {
                        dir('backend') {
                            sh '''
                            npm install
                            '''
                        }
                    }
                }

                stage('Frontend') {
                    steps {
                        dir('frontend') {
                            sh '''
                            npm install
                            '''
                        }
                    }
                }

            }
        }

        // Run tests
        stage('Run Tests') {
            parallel {

                stage('Backend Tests') {
                    steps {
                        dir('backend') {
                            sh '''
                            npm test || true
                            '''
                        }
                    }
                }

                stage('Frontend Tests') {
                    steps {
                        dir('frontend') {
                            sh '''
                            CI=true npm test -- --passWithNoTests
                            '''
                        }
                    }
                }

            }
        }

        // Build React
        stage('Build Frontend') {
            steps {
                dir('frontend') {
                    sh '''
                    export REACT_APP_API_URL=${REACT_APP_API_URL}
                    npm run build
                    '''
                }
            }
        }

        // Docker Login
        stage('Docker Login') {
            steps {
                sh '''
                echo "$DOCKERHUB_PASSWORD" | docker login -u "$DOCKERHUB_USERNAME" --password-stdin
                '''
            }
        }

        // Build Docker Images
        stage('Build Docker Images') {
            parallel {

                stage('Backend Image') {
                    steps {
                        dir('backend') {
                            sh '''
                            docker build -t ${BACKEND_IMAGE}:${IMAGE_TAG} .
                            docker tag ${BACKEND_IMAGE}:${IMAGE_TAG} ${BACKEND_IMAGE}:latest
                            '''
                        }
                    }
                }

                stage('Frontend Image') {
                    steps {
                        dir('frontend') {
                            sh '''
                            docker build -t ${FRONTEND_IMAGE}:${IMAGE_TAG} .
                            docker tag ${FRONTEND_IMAGE}:${IMAGE_TAG} ${FRONTEND_IMAGE}:latest
                            '''
                        }
                    }
                }

            }
        }

        // Push Images
        stage('Push Docker Images') {
            parallel {

                stage('Push Backend') {
                    steps {
                        sh '''
                        docker push ${BACKEND_IMAGE}:${IMAGE_TAG}
                        docker push ${BACKEND_IMAGE}:latest
                        '''
                    }
                }

                stage('Push Frontend') {
                    steps {
                        sh '''
                        docker push ${FRONTEND_IMAGE}:${IMAGE_TAG}
                        docker push ${FRONTEND_IMAGE}:latest
                        '''
                    }
                }

            }
        }

        // Deploy to Kubernetes
        stage('Deploy to Kubernetes') {
            steps {
                sh '''
                kubectl apply -f kubernetes/namespace.yaml

                kubectl apply -f kubernetes/backend-deployment.yaml
                kubectl apply -f kubernetes/backend-service.yaml

                kubectl apply -f kubernetes/frontend-deployment.yaml
                kubectl apply -f kubernetes/frontend-service.yaml
                '''
            }
        }

        // Verify Deployment
        stage('Verify Deployment') {
            steps {
                sh '''
                kubectl get pods -n ${K8S_NAMESPACE}
                kubectl get services -n ${K8S_NAMESPACE}
                '''
            }
        }

    }

    post {

        always {
            echo 'Pipeline finished'
        }

        success {
            echo 'Pipeline completed successfully!'
        }

        failure {
            echo 'Pipeline failed. Check logs.'
        }

    }

}